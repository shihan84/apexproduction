<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow HTTP for development & local servers -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Specific allowed domain -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">apps.varchaswaa.design</domain>
    </domain-config>

    <!-- Common local IPs -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">192.168.1.0</domain>
        <domain includeSubdomains="false">192.168.1.1</domain>
        <domain includeSubdomains="false">192.168.1.2</domain>
        <domain includeSubdomains="false">192.168.1.3</domain>
        <domain includeSubdomains="false">10.0.2.2</domain> <!-- Emulator localhost -->
    </domain-config>
</network-security-config>